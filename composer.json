{
    "name": "sekolahcode/devpulse-wp",
    "description": "Real-time error tracking for WordPress — self-hosted.",
    "type": "wordpress-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "SekolahCode",
            "homepage": "https://github.com/SekolahCode"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "php-stubs/wordpress-stubs": "^6.7",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "DevPulseWP\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "allow-plugins": {}
    }
}
